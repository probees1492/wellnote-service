{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wellnote-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  // Default (used for `wrangler dev`) — points at local/dev bindings.
  // Production deploys MUST use one of the named environments below.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wellnote-dev",
      "database_id": "e3e38812-87a8-4e17-b471-fd335dde67ff",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEMO_BUCKET",
      "bucket_name": "wellnote-memos-dev"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION_KV",
      "id": "a0f3eff539ff4fd7975b78ae1e3893fe"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  // Crons (UTC):
  //   15:00 UTC = 00:00 KST  → daily readonly sweep (memos -> readonly, streaks)
  //   19:00 UTC = 04:00 KST  → prompt-pool generation (Workers AI Qwen2.5-7b)
  "triggers": {
    "crons": [
      "0 15 * * *",
      "0 19 * * *"
    ]
  },
  "vars": {
    "ENVIRONMENT": "dev",
    "CF_ACCOUNT_ID": "6614b80f86c1a1e2de9b22ba93f460f4"
  },

  "env": {
    "dev": {
      "name": "wellnote-api-dev",
      "vars": {
        "ENVIRONMENT": "dev",
        "CF_ACCOUNT_ID": "6614b80f86c1a1e2de9b22ba93f460f4"
      },
      "routes": [
        { "pattern": "api-dev.wellnote.io", "custom_domain": true }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "wellnote-dev",
          "database_id": "e3e38812-87a8-4e17-b471-fd335dde67ff",
          "migrations_dir": "migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "MEMO_BUCKET",
          "bucket_name": "wellnote-memos-dev"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "SESSION_KV",
          "id": "a0f3eff539ff4fd7975b78ae1e3893fe"
        }
      ],
      "ai": {
        "binding": "AI"
      },
      // No cron triggers on this env — Cloudflare's free-plan account limit
      // is 5 crons total, so we keep the two daily jobs (readonly sweep +
      // prompt pool + usage snapshot piggyback) only on dev. Re-enable here
      // once real prod traffic starts.
      "triggers": { "crons": [] }
    },

    "prod": {
      "name": "wellnote-api-prod",
      "vars": {
        "ENVIRONMENT": "prod",
        "CF_ACCOUNT_ID": "6614b80f86c1a1e2de9b22ba93f460f4"
      },
      "routes": [
        { "pattern": "api.wellnote.io", "custom_domain": true }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "wellnote-prod",
          "database_id": "17c85ac4-1e15-4359-9f53-3374283c80c0",
          "migrations_dir": "migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "MEMO_BUCKET",
          "bucket_name": "wellnote-memos-prod"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "SESSION_KV",
          "id": "85719f1cb64d4bcca872e3da59bb7974"
        }
      ],
      "ai": {
        "binding": "AI"
      },
      // No cron triggers on this env (see stage env comment).
      "triggers": { "crons": [] }
    }
  }
}
