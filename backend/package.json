{
  "name": "wellnote-backend",
  "version": "0.1.0",
  "private": true,
  "description": "WellNote backend on Cloudflare Workers (Hono + D1 + R2 + KV)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "migrate:local": "wrangler d1 execute wellnote-db --local --file=./migrations/0001_init.sql",
    "migrate:remote": "wrangler d1 execute wellnote-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8",
    "jose": "^5.9.6",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "better-sqlite3": "^11.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  }
}
